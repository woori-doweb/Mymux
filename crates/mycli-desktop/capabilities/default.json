{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Mymux main-window capability: window control for the close-with-session-save prompt, plus clipboard.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-title",
    "core:event:default",
    "shell:allow-open",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-read-image",
    "updater:default",
    "dialog:allow-open"
  ]
}
