{
  "$schema": "https://raw.githubusercontent.com/nicedayzhu/tauri-schema/refs/heads/v2/tauri.schema.json",
  "productName": "Mymux",
  "version": "0.1.6",
  "mainBinaryName": "Mymux",
  "identifier": "com.mycli.desktop",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mymux — Command Manager",
        "width": 800,
        "height": 560,
        "resizable": true,
        "minWidth": 520,
        "minHeight": 400,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/ChoiGyber/Mymux/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxOUM2OERERUQ2NDE0REQKUldUZEZHVHQzV2ljMGZqSXM3Z25ZNXdwVkhvUzBta2FXUXhXK2lMZnI2Uk5UTmIvajhGV2dzc2UK"
    }
  }
}
